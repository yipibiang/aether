# Copy to ".env" in the project directory (same folder you run helixent from).
# Real OS environment variables override these values. Keys are matched case-insensitively.

ARK_API_KEY=
ARK_BASE_URL=https://api.deepseek.com
HELIXENT_MODEL=deepseek-v4-flash

# Optional — UTF-8 Windows Terminal / chcp 65001; omit on classic GBK PowerShell
# HELIXENT_CONSOLE_CHARSET=UTF-8

# Optional — unset = %USERPROFILE%\.helixent\agent-debug.jsonl ; 0|false|off = disable
# HELIXENT_DEBUG_LOG=
